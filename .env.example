GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
PINECONE_API_KEY=
MONGO_URI=
MONGO_CHECKPOINT_COLLECTION=checkpoints_langgraph_js
MONGO_CHECKPOINT_WRITES_COLLECTION=checkpoint_writes_langgraph_js
PORT=8000
CORS_ORIGIN=*

# Better Auth
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:8000
# Comma-separated list of frontend origins allowed to send credentials, e.g. http://localhost:3000,https://app.hallha.com
AUTH_TRUSTED_ORIGINS=http://localhost:3000
# Optional: parent domain for cross-subdomain cookies (e.g. .hallha.com)
COOKIE_DOMAIN=
# Set false to hide Swagger UI and /openapi.json
SWAGGER_ENABLED=true

# Set true only on MongoDB replica sets (e.g. Atlas). Standalone mongod must use false.
MONGO_ADAPTER_USE_TRANSACTIONS=false

# Optional: pnpm run dev:auth-smoke -- --sign-in
# SMOKE_EMAIL=
# SMOKE_PASSWORD=

LANGSMITH_TRACING=
LANGSMITH_ENDPOINT=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=
AWS_REGION=
AWS_S3_BUCKET_URL=

SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

TAVILY_API_KEY=