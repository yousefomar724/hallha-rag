{
  "name": "hallha-node",
  "version": "0.1.0",
  "private": true,
  "description": "Hallha — Sharia compliance auditor (Node.js port). Express + TypeScript + LangGraph + Pinecone + MongoDB.",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "start": "node --env-file=.env dist/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "dev:auth-smoke": "tsx --env-file=.env scripts/dev-auth-smoke.ts",
    "seed:admin": "tsx --env-file=.env scripts/seed-superadmin.ts",
    "backfill:knowledge-files": "tsx --env-file=.env scripts/backfill-knowledge-files.ts",
    "dev:admin": "pnpm --filter admin dev",
    "build:admin": "pnpm --filter admin build"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1039.0",
    "@aws-sdk/s3-request-presigner": "^3.1039.0",
    "@huggingface/transformers": "^4.2.0",
    "@langchain/core": "^1.1.42",
    "@langchain/groq": "^1.2.0",
    "@langchain/langgraph": "^1.2.9",
    "@langchain/langgraph-checkpoint-mongodb": "^1.3.0",
    "@langchain/pinecone": "^1.0.2",
    "@langchain/textsplitters": "^1.0.1",
    "@opendocsg/pdf2md": "^0.2.6",
    "@pinecone-database/pinecone": "^7.2.0",
    "better-auth": "^1.6.9",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "express-rate-limit": "^8.4.1",
    "groq-sdk": "^1.1.2",
    "langsmith": "^0.5.26",
    "mongodb": "^6.20.0",
    "multer": "^2.1.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "swagger-ui-express": "^5.0.1",
    "unpdf": "^1.6.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.18.10",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  }
}
